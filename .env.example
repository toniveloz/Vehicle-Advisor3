# ==========================================
# Database Configuration
# ==========================================
DATABASE_URL="postgresql://user:password@localhost:5432/vehicle_advisor"

# ==========================================
# Authentication & Security
# ==========================================
JWT_SECRET="your-super-secret-key-change-this-in-production"
OAUTH_SERVER_URL="https://oauth.example.com"

# ==========================================
# OpenAI (LLM)
# ==========================================
OPENAI_API_KEY="your-openai-api-key"
OPENAI_API_URL="https://api.openai.com/v1/chat/completions"
OPENAI_MODEL="gpt-4.1-mini"

# ==========================================
# Supabase (Postgres + Storage)
# ==========================================
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="public-anon-key"
SUPABASE_SERVICE_ROLE_KEY="service-role-key (keep secret)"
SUPABASE_STORAGE_BUCKET="vehicle-photos"

# ==========================================
# Application Configuration
# ==========================================
VITE_APP_ID="your-app-id"
OWNER_OPEN_ID=""

# ==========================================
# CORS & Frontend Configuration
# ==========================================
# Only needed if frontend is on different domain
# Leave empty for same-domain deployment
CORS_ORIGIN=""

# ==========================================
# Frontend Environment (Vite)
# ==========================================
# Only needed for separate frontend deployment
# For same-domain deployment, leave empty
VITE_API_URL=""
VITE_OAUTH_PORTAL_URL="https://oauth-portal.example.com"
