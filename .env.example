# ==========================================
# Database Configuration
# ==========================================
DATABASE_URL="mysql://user:password@localhost:3306/vehicle_advisor"

# ==========================================
# Authentication & Security
# ==========================================
JWT_SECRET="your-super-secret-key-change-this-in-production"
OAUTH_SERVER_URL="https://oauth.example.com"

# ==========================================
# Manus Forge API (LLM + Storage)
# ==========================================
BUILT_IN_FORGE_API_URL="https://forge.example.com"
BUILT_IN_FORGE_API_KEY="your-forge-api-key"

# ==========================================
# Application Configuration
# ==========================================
VITE_APP_ID="your-app-id"
OWNER_OPEN_ID=""

# ==========================================
# CORS & Frontend Configuration
# ==========================================
# Only needed if frontend is on different domain
# Leave empty for same-domain deployment
CORS_ORIGIN=""

# ==========================================
# Frontend Environment (Vite)
# ==========================================
# Only needed for separate frontend deployment
# For same-domain deployment, leave empty
VITE_API_URL=""
VITE_OAUTH_PORTAL_URL="https://oauth-portal.example.com"
VITE_FRONTEND_FORGE_API_URL="https://forge.example.com"
VITE_FRONTEND_FORGE_API_KEY="your-forge-api-key"
